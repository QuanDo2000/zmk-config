/* Custom Defined Behaviors */
/ {
// NOTE: Use the many #define settings below to customize this keymap!
#define DIFFICULTY_LEVEL  0  // 0:custom, 1:easy -> 5:hard (see below)
#define ENFORCE_BILATERAL    // cancels single-handed home row mod+tap
#define SPACE_FORGIVENESS    // allow lingering taps on the space bar
// TIP: Add more setting overrides here instead of editing them below.

//////////////////////////////////////////////////////////////////////////////
//
// Sunaku's Keymap v41 -- "Glorious Engrammer"
// - https://github.com/sunaku/glove80-keymaps
//
//////////////////////////////////////////////////////////////////////////////

//
// OPERATING_SYSTEM defines which operating system you intend to use
// with this keymap, because shortcuts vary across operating systems.
//
// - https://zmk.dev/docs/codes
// - https://en.wikipedia.org/wiki/Table_of_keyboard_shortcuts
//
// This setting also affects the UNICODE() function defined below, as
// each OS has different shortcuts for typing Unicode hex characters.
//
// NOTE: You may need to enable Unicode hexadecimal input in your OS:
// - (macOS) https://uknowit.uwgb.edu/page.php?id=22623
//     and   https://github.com/ldanet/unicode-hex-input-fix
// - (Linux) https://help.ubuntu.com/stable/ubuntu-help/tips-specialchars.html.en#ctrlshiftu
// - (Windows) https://github.com/samhocevar/wincompose
//
// Specifically, Windows users should be running the WinCompose tool,
// which lets you type Unicode characters via hexadecimal codepoints.
//
// Windows/Linux Def
#define _C      LC
#define _REDO   _C(Y)
#define _UNDO   _C(Z)
#define _CUT    _C(X)
#define _COPY   _C(C)
#define _PASTE  _C(V)
#define _FIND   _C(F)
// Mac Def
#define _C_Mac      LG
#define _REDO_Mac   _C_Mac(LS(Z))
#define _HOME_Mac   _C_Mac(LEFT)
#define _END_Mac    _C_Mac(RIGHT)
#define _UNDO_Mac   _C_Mac(Z)
#define _CUT_Mac    _C_Mac(X)
#define _COPY_Mac   _C_Mac(C)
#define _PASTE_Mac  _C_Mac(V)
#define _FIND_Mac   _C_Mac(F)
#define _PSCRN_Mac  _C_Mac(LS(N4))

//
// Keymap specific knowledge of the base layer's alpha + ZMK layout
//
#define KEY_LH_C6R1 EQUAL
#define KEY_LH_C5R1 N1
#define KEY_LH_C4R1 N2
#define KEY_LH_C3R1 N3
#define KEY_LH_C2R1 N4
#define KEY_LH_C1R1 N5
#define KEY_RH_C1R1 N6
#define KEY_RH_C2R1 N7
#define KEY_RH_C3R1 N8
#define KEY_RH_C4R1 N9
#define KEY_RH_C5R1 N0
#define KEY_RH_C6R1 MINUS
#define KEY_LH_C6R2 GRAVE
#define KEY_LH_C5R2 Q
#define KEY_LH_C4R2 W
#define KEY_LH_C3R2 E
#define KEY_LH_C2R2 R
#define KEY_LH_C1R2 T
#define KEY_RH_C1R2 Y
#define KEY_RH_C2R2 U
#define KEY_RH_C3R2 I
#define KEY_RH_C4R2 O
#define KEY_RH_C5R2 P
#define KEY_RH_C6R2 BSLH
#define KEY_LH_C6R3 CAPS
#define KEY_LH_C5R3 A
#define KEY_LH_C4R3 S
#define KEY_LH_C3R3 D
#define KEY_LH_C2R3 F
#define KEY_LH_C1R3 G
#define KEY_RH_C1R3 H
#define KEY_RH_C2R3 J
#define KEY_RH_C3R3 K
#define KEY_RH_C4R3 L
#define KEY_RH_C5R3 SEMI
#define KEY_RH_C6R3 SQT
#define KEY_LH_C6R4 LSFT
#define KEY_LH_C5R4 Z
#define KEY_LH_C4R4 X
