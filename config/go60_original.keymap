#define KEY_LH_C2R4 V
#define KEY_LH_C1R4 B
#define KEY_RH_C1R4 N
#define KEY_RH_C2R4 M
#define KEY_RH_C3R4 COMMA
#define KEY_RH_C4R4 DOT
#define KEY_RH_C5R4 FSLH
#define KEY_RH_C6R4 RSFT
#define KEY_LH_C4R5 LEFT
#define KEY_LH_C3R5 RIGHT
#define KEY_LH_C2R5 ESC
#define KEY_RH_C2R5 DELETE
