      };
      #endif

      #ifdef LAYER_Button_Mac
      Button_Mac {
        bindings = <
          RED ___ ___ ___ ___ ___                   ___ ___ ___ ___ ___ RED
          ___ ___ GDN ORN ORN ORN                   ORN ORN ORN ORN ___ ___
          ___ MAJ CYN GRN YLW ORN                   ORN YLW GRN CYN MAJ ___
          ___ ORN ORN ORN ORN ORN                   ORN ORN ORN ORN ORN ___
                  ___ ___ COR                           COR ___ ___
