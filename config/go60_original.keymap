                                         &none               &none   &tog LAYER_System                                      &tog LAYER_Symbol                &none                &none
                                                 &tog LAYER_Cursor    &tog LAYER_Mouse            &none            &none    &tog LAYER_Number  &tog LAYER_Function
            >;
        };

        layer_Magic {
            bindings = <
       &to 0            &to 1            &to 2            &to 3            &to 4       &bt BT_CLR  &none  &none  &none  &none  &none  &bt BT_CLR_ALL
 &bootloader  &rgb_ug RGB_SPI  &rgb_ug RGB_SAI  &rgb_ug RGB_HUI  &rgb_ug RGB_BRI  &rgb_ug RGB_TOG  &none  &none  &none  &none  &none     &bootloader
  &sys_reset  &rgb_ug RGB_SPD  &rgb_ug RGB_SAD  &rgb_ug RGB_HUD  &rgb_ug RGB_BRD  &rgb_ug RGB_EFF  &none  &none  &none  &none  &none      &sys_reset
       &none            &bt_0            &bt_1            &bt_2            &bt_3            &none  &none  &none  &none  &none  &none           &none
                                  &out OUT_USB            &none            &none                          &none  &none  &none
                                                          &none            &none            &none  &none  &none  &none
            >;
        };
    };
};

&cirque_rh_listener {
    input-processors = <&zip_xy_scaler 2 1>;
    layer_Mouse {
        layers = <LAYER_Mouse>;
        input-processors = <&zip_xy_scaler 4 1>;
    };
};

&cirque_lh_listener {
    input-processors = <&zip_xy_to_scroll_mapper>, <&zip_click_to_right_click_mapper>;
};
